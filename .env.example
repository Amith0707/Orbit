# --- Server ---
PORT=5000
NODE_ENV=development

# Postgres connection string (local Postgres for dev, or a Supabase "Session pooler" URI for production).
DATABASE_URL=postgresql://user@localhost:5432/calfus_orbit_dev

# Signs/verifies short-lived JWT access tokens.
JWT_SECRET=replace-with-a-long-random-string

# Required for every AI feature to make real OpenAI API calls.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Reserved for future use (e.g. Supabase Storage). Not required to run the app.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- Client ---
VITE_API_URL=http://localhost:5000/api
