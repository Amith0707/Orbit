# --- Server ---
PORT=5000
NODE_ENV=development

# Your Supabase project's API URL (Project Settings -> API -> Project URL).
SUPABASE_URL=https://<project-ref>.supabase.co

# Service role (secret) key -- NOT the anon/publishable key. The server uses this to
# read/write every table via supabase-js, bypassing RLS; the app enforces its own
# authorization in Express middleware. Never expose this key to the browser.
# Get it from: Project Settings -> API -> Project API keys -> service_role.
SUPABASE_SERVICE_ROLE_KEY=

# Signs/verifies short-lived JWT access tokens.
JWT_SECRET=replace-with-a-long-random-string

# Required for every AI feature to make real OpenAI API calls.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# --- Client ---
VITE_API_URL=http://localhost:5000/api
